# Example Terraform variables file
# Copy this to terraform.tfvars and fill in your values

aws_region = "us-east-1"
environment = "prod"

# IMPORTANT: Must be globally unique across all AWS accounts
# Replace with: your-company-shopsmart-prod-YYYYMMDD (or similar unique pattern)
s3_bucket_name = "shopsmart-app-data-prod-20240101"

ecr_repository_name = "shopsmart-app"
ecs_cluster_name    = "shopsmart-cluster"

# Resource sizing (adjust based on your application needs)
ecs_task_cpu     = 512      # 256, 512, 1024, 2048, 4096
ecs_task_memory  = 1024     # 512, 1024, 2048, 3072, 4096, 5120, 6144, 7168, 8192
ecs_desired_count = 2       # Minimum 2 for redundancy
ecs_max_capacity = 4        # Maximum for auto-scaling

container_image_tag = "latest"

# Your existing VPC and subnet IDs
vpc_id = "vpc-xxxxxxxxx"
public_subnets = [
  "subnet-xxxxxxxxx",
  "subnet-yyyyyyyyy"
]
private_subnets = [
  "subnet-zzzzzzzzz",
  "subnet-wwwwwwwww"
]
